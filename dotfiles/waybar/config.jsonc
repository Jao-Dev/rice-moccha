{
   "include": [
     "$HOME/.config/waybar/Modules",
     ],

    "layer": "top",
    "position": "top",
    "margin-top": 0, 
    "modules-left": [ "hyprland/workspaces", "tray","mpris", "custom/pacman"],
    "modules-center": [ "clock" ],
    "modules-right": [ "bluetooth", "network", "pulseaudio" ],
    "sway/window": {
        "max-length": 100
    },
    
 
}

